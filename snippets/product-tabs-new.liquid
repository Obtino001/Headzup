{%- style -%}
  /* --- Block Padding Logic --- */
  .block-padding-{{ block.id }} {
    padding-top: {{ block.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ block.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .block-padding-{{ block.id }} {
      padding-top: {{ block.settings.padding_top }}px;
      padding-bottom: {{ block.settings.padding_bottom }}px;
    }
  }

  /* --- Top Header: Tabs on Left, Buttons on Right --- */
  .joieem-header-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 2rem;
    flex-wrap: wrap;
    gap: 2rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 1rem;
  }

  .joieem-tabs-container {
    flex: 1 1 auto;
    margin-bottom: 0 !important;
    padding-bottom: 0 !important;
  }

  /* Accent yellow underline for active tab */
  .product-block-{{ block.id }} .tabs > li span:first-of-type::after {
    background-color: #0c2340;
    height: 3px;
    bottom: -11px; /* Align to the border bottom */
  }

  .product-block-{{ block.id }} .tabs > li.current {
    --text: var(--text-dark);
  }

  .joieem-actions-container {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  /* Custom button overrides for pill shape and colors */
  .product-block-{{ block.id }} .btn-outline-custom {
    border-color: var(--border);
    transition: all 0.3s ease;
  }
  .product-block-{{ block.id }} .btn-outline-custom:hover {
    border-color: #0c2340;
    background-color: transparent;
    color: var(--text-dark);
  }
  .product-block-{{ block.id }} .btn-solid-custom {
    background-color: #0c2340;
    border-color: #0c2340;
    transition: opacity 0.3s ease;
  }
  .product-block-{{ block.id }} .btn-solid-custom:hover {
    opacity: 0.85;
    background-color: #0c2340;
    border-color: #0c2340;
  }

  /* --- Main Content Layout --- */
  .joieem-content-grid {
    display: block;
  }

  .joieem-text-column {
    position: relative;
    display: flex;
    flex-direction: column;
  }

  /* Style tab transitions */
  .product-block-{{ block.id }} .tab-content {
    transition: opacity 0.35s ease, transform 0.35s ease;
    transform: translateY(8px);
  }
  .product-block-{{ block.id }} .tab-content.current {
    transform: translateY(0);
  }

  .joieem-text-area {
    line-height: 1.6;
    color: var(--text);
  }

  .joieem-features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    row-gap: 4rem;
    column-gap: 3rem;
    padding-block: 3rem;
  }

  .joieem-feature-block {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    align-items: flex-start;
  }

  .joieem-feature-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-dark);
  }

  .joieem-feature-icon img,
  .joieem-feature-icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .joieem-feature-text {
    font-size: var(--font-body-medium);
    line-height: 1.4;
    color: var(--text-dark);
    font-weight: 500;
  }

  /* --- Mobile Responsiveness --- */
  @media screen and (max-width: 989px) {
    .joieem-features-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .joieem-header-wrapper {
      flex-direction: column;
      align-items: flex-start;
      gap: 2.5rem;
    }
    
    .joieem-tabs-container {
      width: 100%;
    }

    .joieem-actions-container {
      width: 100%;
      flex-direction: column;
    }

    .joieem-actions-container .btn {
      width: 100%;
      text-align: center;
    }
  }
{%- endstyle -%}

<tabs-component class="product-block-{{ block.id }} page-width block-padding-{{ block.id }} product-tabs" {{ block.shopify_attributes }}>
  
  <div class="joieem-header-wrapper">
    <native-scrollbar class="tabs__head product-tabs__head joieem-tabs-container">
      <ul class="tabs product-tabs-title" data-scrollbar data-scrollbar-slider>
        {%- if block.settings.tab_1 != blank -%}
          <li class="tab-link tab-link-0 current" data-tab="0" tabindex="0">
            <span>{{ block.settings.tab_1 }}</span>
          </li>
        {%- endif -%}
        {%- if block.settings.tab_2 != blank -%}
          <li class="tab-link tab-link-1" data-tab="1" tabindex="0">
            <span>{{ block.settings.tab_2 }}</span>
          </li>
        {%- endif -%}
        {%- if block.settings.tab_3 != blank -%}
          <li class="tab-link tab-link-2" data-tab="2" tabindex="0">
            <span>{{ block.settings.tab_3 }}</span>
          </li>
        {%- endif -%}
        {%- if block.settings.tab_4 != blank -%}
          <li class="tab-link tab-link-3" data-tab="3" tabindex="0">
            <span>{{ block.settings.tab_4 }}</span>
          </li>
        {%- endif -%}
        {%- if block.settings.tab_5 != blank -%}
          <li class="tab-link tab-link-4" data-tab="4" tabindex="0">
            <span>{{ block.settings.tab_5 }}</span>
          </li>
        {%- endif -%}
      </ul>

      <button
        type="button"
        class="tabs__arrow tabs__arrow--prev product-tabs__arrow product-tabs__arrow--prev is-hidden"
        data-scrollbar-arrow-prev
      >
        {%- render 'icon-nav-arrow-left' -%}
        <span class="visually-hidden">{{ 'products.general.see_all' | t }}</span>
      </button>

      <button
        type="button"
        class="tabs__arrow tabs__arrow--next product-tabs__arrow product-tabs__arrow--next is-hidden"
        data-scrollbar-arrow-next
      >
        {%- render 'icon-nav-arrow-right' -%}
        <span class="visually-hidden">{{ 'products.general.see_all' | t }}</span>
      </button>
    </native-scrollbar>

  </div>

  <div class="joieem-content-grid">
    
    <div class="joieem-text-column">
      {%- if block.settings.tab_1 != blank -%}
        <div class="tab-content tab-content-0 current rte">
          <div class="joieem-features-grid">
            {%- for i in (1..6) -%}
              {%- assign img_key = 'f' | append: i | append: '_image' -%}
              {%- assign icon_key = 'f' | append: i | append: '_icon' -%}
              {%- assign title_key = 'f' | append: i | append: '_title' -%}
              
              {%- assign f_image = block.settings[img_key] -%}
              {%- assign f_icon = block.settings[icon_key] -%}
              {%- assign f_title = block.settings[title_key] -%}

              {%- if f_title != blank -%}
                <div class="joieem-feature-block">
                  <div class="joieem-feature-icon">
                    {%- if f_image != blank -%}
                      {{ f_image | image_url: width: 64 | image_tag: loading: 'lazy' }}
                    {%- endif -%}
                  </div>
                  <div class="joieem-feature-text">{{ f_title }}</div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      {%- if block.settings.tab_2 != blank -%}
        <div class="tab-content tab-content-1 rte">
          <div class="joieem-text-area">{{ block.settings.tab_2_content }}</div>
        </div>
      {%- endif -%}

      {%- if block.settings.tab_3 != blank -%}
        <div class="tab-content tab-content-2 rte">
          <div class="joieem-text-area">{{ block.settings.tab_3_content }}</div>
        </div>
      {%- endif -%}

      {%- if block.settings.tab_4 != blank -%}
        <div class="tab-content tab-content-3 rte">
          <div class="joieem-text-area">{{ block.settings.tab_4_content }}</div>
        </div>
      {%- endif -%}

      {%- if block.settings.tab_5 != blank -%}
        <div class="tab-content tab-content-4 rte">
          <div class="joieem-text-area">{{ block.settings.tab_5_content }}</div>
        </div>
      {%- endif -%}
    </div>

  </div>
</tabs-component>