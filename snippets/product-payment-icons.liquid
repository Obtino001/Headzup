{%- if settings.cart_payment_icons -%}
    <div class="product__payment__icons payment-icons inline-list" 
    {{ block.shopify_attributes }}
    {{ block_style }}>
      {%- for i in (1..6) -%}
        {%- assign payment_setting = 'payment_' | append: i -%}
        {%- if settings[payment_setting] -%}
          <li>{{ settings[payment_setting] | image_url: height: 17 | image_tag }}</li>
        {%- endif -%}
      {%- endfor -%}
      <li><svg xmlns="http://www.w3.org/2000/svg" width="30px" height="20px" viewBox="0 0 30 20">
    <image href="data:image/png;base64,"
    width="30" height="20" />
</svg></li>
    </div>
  {%- endif -%}