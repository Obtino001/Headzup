{{ 'product-upsell-addon.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-upsell-addon.js' | asset_url | append: '?v=' | append: shop.metafields.cache.version.value | default: '1' }}" defer="defer"></script>

{%- liquid
  assign gift_product = block.settings.gift_product
  assign accent_color = block.settings.accent_color | default: "#0c2340"
  assign padding_top = block.settings.padding_top | default: 16
  assign padding_bottom = block.settings.padding_bottom | default: 16
-%}

{%- if gift_product != blank -%}
  {%- assign current_variant = gift_product.selected_or_first_available_variant -%}
  {%- if current_variant.available -%}
    <upsell-addon class="product__block gift-wrap-addon-container" style="--upsell-accent: {{ accent_color }}; padding-top: {{ padding_top }}px; padding-bottom: {{ padding_bottom }}px;" {{ block.shopify_attributes }}>
      
      <div class="gift-wrap-card upsell-addon__item is-unchecked" data-upsell-item data-selected-variant-id="{{ current_variant.id }}" data-selected-price="{{ current_variant.price }}" data-selected-compare="{{ current_variant.compare_at_price | default: current_variant.price }}">
        
        <div class="upsell-addon__checkbox-wrapper">
          <div class="upsell-addon__checkbox">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </div>
        </div>

        <div class="gift-wrap-card__image-wrapper">
          {%- if gift_product.featured_image != blank -%}
            <img src="{{ gift_product.featured_image | image_url: width: 100 }}" alt="{{ gift_product.title | escape }}" class="gift-wrap-card__image" loading="lazy">
          {%- else -%}
            <div class="gift-wrap-card__image placeholder-bg"></div>
          {%- endif -%}
        </div>

        <div class="gift-wrap-card__details">
          {%- if gift_product.vendor != blank -%}
            <p class="gift-wrap-card__vendor">{{ gift_product.vendor }}</p>
          {%- endif -%}
          
          <h3 class="gift-wrap-card__title">{{ gift_product.title }}</h3>
          
          <div class="gift-wrap-card__price">
            {{ current_variant.price | money }}
          </div>
        </div>

      </div>

    </upsell-addon>

    <style>
      .gift-wrap-addon-container {
        display: block;
        width: 100%;
      }
      .gift-wrap-card {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 15px;
        background: #fff;
        cursor: pointer;
        transition: all 0.2s ease;
        padding: 10px;
        border: 1px solid #e1e5e8;
        border-radius: 4px;
      }
      .gift-wrap-card__image-wrapper {
        flex-shrink: 0;
        width: 50px;
        height: 50px;
        border-radius: 4px;
        overflow: hidden;
        border: 1px solid #eee;
      }
      .gift-wrap-card__image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      .gift-wrap-card__details {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 2px;
      }
      .gift-wrap-card__vendor {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        color: #888;
        letter-spacing: 0.05em;
        margin: 0;
      }
      .gift-wrap-card__title {
        font-size: 14px;
        font-weight: 600;
        color: #0c2340;
        margin: 0;
      }
      .gift-wrap-card__price {
        font-size: 13px;
        font-weight: 500;
        color: #0c2340;
        margin-top: 2px;
      }
      
      /* Toggle Styles */
      .gift-wrap-card.is-checked {
        border-color: var(--upsell-accent);
        background-color: #fafafa;
      }
    </style>
  {%- endif -%}
{%- endif -%}
