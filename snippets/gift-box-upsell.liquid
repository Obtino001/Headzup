{% if gift_box_product != blank and gift_box_product.available %}
  <div class="gift-box-upsell" style="display: flex; align-items: center; gap: 10px; background: #f9f9f9; padding: 15px; border-radius: 6px; margin-top: 15px;">
    {% assign is_in_cart = false %}
    {% for item in cart.items %}
      {% if item.product_id == gift_box_product.id %}
        {% assign is_in_cart = true %}
        {% assign gift_box_key = item.key %}
      {% endif %}
    {% endfor %}
    
    <input type="checkbox" id="gift_box_checkbox_{{ position }}" class="gift-box-checkbox" data-variant-id="{{ gift_box_product.variants.first.id }}" data-key="{{ gift_box_key }}" {% if is_in_cart %}checked{% endif %} style="width: 20px; height: 20px;">
    <label for="gift_box_checkbox_{{ position }}" style="margin: 0; cursor: pointer; font-size: 15px;">
      <strong>Add gift wrapping for {{ gift_box_product.price | money }}</strong>
    </label>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var checkbox = document.getElementById('gift_box_checkbox_{{ position }}');
      if(checkbox) {
        checkbox.addEventListener('change', function(e) {
          const isChecked = e.target.checked;
          const variantId = e.target.getAttribute('data-variant-id');
          const key = e.target.getAttribute('data-key');
          
          e.target.disabled = true;
          document.body.style.cursor = 'wait';

          if (isChecked) {
            fetch(window.Shopify.routes.root + 'cart/add.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                items: [{
                  id: variantId,
                  quantity: 1
                }]
              })
            })
            .then(response => response.json())
            .then(data => {
              window.location.reload();
            })
            .catch(error => {
              console.error('Error:', error);
              e.target.disabled = false;
              document.body.style.cursor = 'default';
            });
          } else {
            fetch(window.Shopify.routes.root + 'cart/change.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                id: key,
                quantity: 0
              })
            })
            .then(response => response.json())
            .then(data => {
              window.location.reload();
            })
            .catch(error => {
              console.error('Error:', error);
              e.target.disabled = false;
              document.body.style.cursor = 'default';
            });
          }
        });
      }
    });
  </script>
{% endif %}
