{%- liquid
  assign animation_name = 'drawer-items-fade'
  assign animation_duration = 500
  assign highlight_item = highlight_item | downcase | strip_html | escape
  assign link_title_lowercase = link.title | downcase | strip_html | escape
  assign expands = false
  assign block_count = 0
  assign link_level = link_level | default: 0
  assign link_level_next = link_level | plus: 1
  assign forloop_index = forloop_index | default: 1
  assign collection_icon = link.object.metafields.custom.collection_icon.value

  if section
    assign index = index | append: ""
    for block in section.blocks
      if block.settings.position == index
        assign block_count = block_count | plus: 1
      endif
    endfor
  endif

  if link.levels > 0 or block_count > 0
    assign expands = true
    assign key = link.url | append: link.title | append: link.levels | append: unique | append: block.type | append: index | md5
  endif

  if secondary_menu
    assign expands = false
  endif
-%}

{%- liquid
  assign should_add_regular_class = false
  if collection_icon != blank
    unless link.title contains ':highlight-menu'
      assign should_add_regular_class = true
    endunless
  endif
-%}

{%- capture link_markup -%}
  {%- if link.url == "#" -%}
    <span class="sliderow__title sliderow__title--level-{{ link_level }} {% if secondary_menu %} sliderow__title--secondary{% endif %}{% if highlight_item == link_title_lowercase %} sliderow__title--highlight{% endif %}{% if link.title contains ':highlight-menu' %} navlink--highlight-menu{% endif %}{% if link.title contains ':hidden' %} hidden-title{% endif %}{% if collection_icon != blank %} navlink-collection-icon{% endif %}" data-sliderule-close="sliderule-{{ key }}">
      {% if collection_icon != blank %}
        {% render 'image', image: collection_icon, width: 10 %}
      {% endif %}
      {{ link.title | replace: ':highlight-menu', '' | strip_html | escape }}
    </span>
  {%- else -%}
    <a class="sliderow__title sliderow__title--level-{{ link_level }}{% if secondary_menu %} sliderow__title--secondary{% endif %}{% if highlight_item == link_title_lowercase %} sliderow__title--highlight{% endif %}{% if link.title contains ':highlight-menu' %} navlink--highlight-menu{% endif %}{% if link.title contains ':hidden' %} hidden-title{% endif %}{% if collection_icon != blank %} navlink-collection-icon{% endif %}" href="{{ link.url }}">
      {% if collection_icon != blank %}
        {% render 'image', image: collection_icon, width: 10 %}
      {% endif %}
      <span class="nav-link-collections{% if should_add_regular_class %} navlink--regular{% endif %}">
        {{ link.title | replace: ':highlight-menu', '' | strip_html | escape }}
        {%- if expands or link_level > 0 -%}
          {%- render 'superscript', link_collection: link -%}
        {%- endif -%}
      </span>
    </a>
  {%- endif -%}
{%- endcapture -%}

<div class="sliderule__wrapper sliderule__wrapper--level-{{ link_level }} {% if secondary_menu %} sliderule__wrapper--secondary{% endif %}">
  {%- if expands and block.type != 'menu-columns' and link_level == 0 -%}
    <mobile-sliderule id="sliderule-{{ key }}">
      <button class="sliderow sliderow--level-{{ link_level }} " type="button"
        data-sliderule-open="sliderule-{{ key }}">
        <span class="sliderow__title sliderow__title--level-{{ link_level }}{% if secondary_menu %} sliderow__title--secondary{% endif %}{% if collection_icon != blank %} navlink-collection-icon{% endif %}{% if highlight_item == link_title_lowercase %} sliderow__title--highlight{% endif %}{% if link.title contains ':highlight-menu' %} navlink--highlight-menu{% endif %}{% if link.title contains ':hidden' %} hidden-title{% endif %}">
          {% if collection_icon != blank %}
            {% render 'image', image: collection_icon, width: 10 %}
          {% endif %}
          <span>
            {{ link.title | replace: ':highlight-menu', '' | strip_html | escape }}
            {%- if link_level > 0 -%}
              {%- render 'superscript', link_collection: link -%}
            {%- endif -%}
          </span>
          <span class="sliderule__chevron sliderule__chevron--right">
            {%- render 'icon-arrow-right' -%}
            <span class="visually-hidden">{{ 'general.accessibility.show_menu' | t }}</span>
          </span>
        </span>
      </button>

      <div class="mobile__menu__dropdown mobile__menu__dropdown--level-{{ link_level }} sliderule__panel"
        data-sliderule="{{ link_level_next }}"
        data-scroll-lock-scrollable>
        <div class="sliderow sliderow--back"
        data-animates="{{ link_level_next }}"
        data-animation="{{ animation_name }}"
        data-animation-delay="150"
        data-animation-duration="{{ animation_duration }}">
          <button class="sliderow__back-button" type="button" data-sliderule-close="sliderule-{{ key }}">
            <span class="sliderule__chevron sliderule__chevron--left">
              {%- render 'icon-arrow-left-custom' -%}
              <span class="visually-hidden">{{ 'general.accessibility.exit_menu' | t }}</span>
            </span>
          </button>
          {{ link_markup }}
        </div>
        <div class="sliderow__links sliderow__links--level-{{ link_level }}" data-links>
          {%- for link in link.links -%}
            {%- assign index_recursive = index | append: 'x' | append: forloop.index -%}
            {%- render 'nav-item-mobile', link: link, index: index_recursive, forloop_index: forloop.index, link_level: link_level_next, highlight_item: highlight_item, unique: unique -%}
          {%- endfor -%}

          {%- if section and section.blocks.size > 0 -%}
            {%- assign header_blocks = '' -%}
            
            {%- for block in section.blocks -%}
              {%- if block.settings.position == index -%}
                {%- capture header_blocks -%}
                  {{ header_blocks }}
                  {% render 'header-block', block: block, link_level_next: link_level_next, is_mobile: true %}
                {%- endcapture -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if header_blocks != '' -%}
              <div class="sliderule-grid sliderule-grid-blocks sliderule-grid--level-{{ link_level }} blocks-{{ block_count }}">
                {{ header_blocks }}
              </div>
            {%- endif -%}
          {%- endif -%}
        </div>
      </div>
    </mobile-sliderule>

  {%- elsif expands and link_level > 0 -%}
    <div class="sliderow sliderow--level-{{ link_level }} {% if link.title contains ':highlight-menu' %}sliderow--highlight-menu{% endif %}">
      {{ link_markup }}

      <div class="sliderow__data-links" data-links>
        {%- for link in link.links -%}
          {%- assign index_recursive = index | append: 'x' | append: forloop.index -%}
          {%- render 'nav-item-mobile', link: link, index: index_recursive, forloop_index: forloop.index, link_level: link_level_next, highlight_item: highlight_item, unique: unique -%}
        {%- endfor -%}

        {%- if section and section.blocks.size > 0 -%}
          {%- assign header_blocks = '' -%}
          {%- for block in section.blocks -%}
            {%- if block.settings.position == index-%}
              {%- capture header_blocks -%}
                {{ header_blocks }}
                {% render 'header-block', block: block, link_level_next: link_level_next, is_mobile: true %}
              {%- endcapture -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if header_blocks != '' -%}
            <div class="sliderule-grid sliderule-grid--level-{{ link_level }} blocks-{{ block_count }}">
              {{ header_blocks }}
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>

  {%- else -%}
    <div class="sliderow sliderow--level-{{ link_level }}">
      {{ link_markup }}
    </div>
  {%- endif -%}
</div>
