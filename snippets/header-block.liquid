{% comment %}
Header block content, used in both mobile header and desktop header.

Accepts a block, returns the content to render for that block.

Required params:
* block: (Object) the block that should be rednered.
* image_count: (Int) the number of images per menu item
* link_columns: (Int) the number of columns with links. Max: 3
* only_images: (Boolean) whether we have images only or images with links
* is_mobile: (Boolean) if the block is called from the mobile nav. Default: false
* link_level_next: (Int) the index of the next link level

{% render 'header-block', block: block, image_count: image_count, only_images: only_images, link_columns: link_columns, link_level_next: link_level_next %}

{% endcomment %}

{%- liquid
  assign grid_style = settings.grid_style
  assign animation_name = 'drawer-items-fade'
  assign animation_duration = 500
  assign text_color = block.settings.text_color
  assign width_class = 'menu__block--narrow'
  assign aspect_ratio = 1 | divided_by: block.settings.aspect_ratio
  assign link_columns = link_columns | at_most: 3 | default: 1
  assign is_mobile = is_mobile | default: false
  if block.settings.wide_image
    assign width_class = 'menu__block--wide'
    assign link_columns = 1
  endif

  assign title = block.settings.title
  assign text = block.settings.link_text
  assign link = block.settings.link
  assign image = block.settings.image

  assign full_width = '100vw'
  if grid_style == 'classic'
    assign full_width = '(100vw - 100px)'
  endif

  if only_images
    assign columns = image_count
  else
    assign columns = image_count | plus: link_columns
  endif

  assign sizes = '(min-width: 990px) calc(' | append: full_width | append: ' / ' | append: columns | append: '), (min-width: 380px) 350px, calc(100vw - 30px)'

  if is_mobile
    assign sizes = '(min-width: 380px) 350px, calc(100vw - 30px)'
  endif

-%}
{% if block.type == 'brands' %}
  <div class="menu__block menu__block-brands {{ width_class }}" {{ block.shopify_attributes }}
    {% if link_level_next %}
      data-animates="{{ link_level_next }}"
      data-animation="{{ animation_name }}"
      data-animation-delay="{{ animation_delay }}"
      data-animation-duration="{{ animation_duration }}"
    {% endif %}>
    <div class="header__dropdown__brands header__dropdown__brands--categorized">
      {% assign brand_metaobject_values = metaobjects.brands.values %}
      {% if page.metafields.custom.chapter_two or product.metafields.custom.chapter_two or collection.metafields.custom.chapter_two %}
        {% assign brand_metaobject_values = metaobjects.brands_chapter_two.values %}
      {% endif %}
      
      {% assign premium_list = block.settings.premium_brands | downcase | split: ',' %}
      {% assign streetwear_list = block.settings.streetwear_brands | downcase | split: ',' %}
      {% assign sports_list = block.settings.sports_brands | downcase | split: ',' %}
      {% assign lifestyle_list = block.settings.lifestyle_brands | downcase | split: ',' %}

      {% capture premium_html %}{% endcapture %}
      {% capture streetwear_html %}{% endcapture %}
      {% capture sports_html %}{% endcapture %}
      {% capture lifestyle_html %}{% endcapture %}
      {% capture other_html %}{% endcapture %}

      {%- for brand in brand_metaobject_values -%}
        {% assign b_name = brand.title | downcase %}
        {% assign category = 'other' %}

        {% for item in premium_list %}
          {% assign item_stripped = item | strip %}
          {% if b_name contains item_stripped and item_stripped != blank %}{% assign category = 'premium' %}{% break %}{% endif %}
        {% endfor %}
        
        {% if category == 'other' %}
          {% for item in streetwear_list %}
            {% assign item_stripped = item | strip %}
            {% if b_name contains item_stripped and item_stripped != blank %}{% assign category = 'streetwear' %}{% break %}{% endif %}
          {% endfor %}
        {% endif %}

        {% if category == 'other' %}
          {% for item in sports_list %}
            {% assign item_stripped = item | strip %}
            {% if b_name contains item_stripped and item_stripped != blank %}{% assign category = 'sports' %}{% break %}{% endif %}
          {% endfor %}
        {% endif %}

        {% if category == 'other' %}
          {% for item in lifestyle_list %}
            {% assign item_stripped = item | strip %}
            {% if b_name contains item_stripped and item_stripped != blank %}{% assign category = 'lifestyle' %}{% break %}{% endif %}
          {% endfor %}
        {% endif %}

        {% capture brand_html %}
          <div class="brand-item">
            {%- if brand.link_collection.value.url != blank -%}
              <a href="{{ brand.link_collection.value.url }}" class="brand-link">
            {%- else -%}
              <div class="brand-link">
            {%- endif -%}
            
            {%- if brand.image != blank -%}
              <div class="brand-image">
                <img src="{{ brand.image | image_url: width: 40 }}" alt="{{ brand.title | escape }}" width="40" height="40" loading="lazy">
              </div>
            {%- endif -%}
            
            {%- if brand.title != blank -%}
              <span class="brand-title">{{ brand.title | escape }}</span>
            {%- endif -%}
            
            {%- if brand.link_collection.value.url != blank -%}
              </a>
            {%- else -%}
              </div>
            {%- endif -%}
          </div>
        {% endcapture %}

        {% if category == 'premium' %}
          {% capture premium_html %}{{ premium_html }}{{ brand_html }}{% endcapture %}
        {% elsif category == 'streetwear' %}
          {% capture streetwear_html %}{{ streetwear_html }}{{ brand_html }}{% endcapture %}
        {% elsif category == 'sports' %}
          {% capture sports_html %}{{ sports_html }}{{ brand_html }}{% endcapture %}
        {% elsif category == 'lifestyle' %}
          {% capture lifestyle_html %}{{ lifestyle_html }}{{ brand_html }}{% endcapture %}
        {% else %}
          {% capture other_html %}{{ other_html }}{{ brand_html }}{% endcapture %}
        {% endif %}
      {%- endfor -%}

      {% if premium_html != blank %}
        <div class="brands-category">
          <h4 class="brands-category-title">Premium</h4>
          <div class="brands-category-list">{{ premium_html }}</div>
        </div>
      {% endif %}
      {% if streetwear_html != blank %}
        <div class="brands-category">
          <h4 class="brands-category-title">Streetwear</h4>
          <div class="brands-category-list">{{ streetwear_html }}</div>
        </div>
      {% endif %}
      {% if sports_html != blank %}
        <div class="brands-category">
          <h4 class="brands-category-title">Sports/MLB</h4>
          <div class="brands-category-list">{{ sports_html }}</div>
        </div>
      {% endif %}
      {% if lifestyle_html != blank %}
        <div class="brands-category">
          <h4 class="brands-category-title">Lifestyle</h4>
          <div class="brands-category-list">{{ lifestyle_html }}</div>
        </div>
      {% endif %}
      {% if other_html != blank %}
        <div class="brands-category">
          <h4 class="brands-category-title">Other Brands</h4>
          <div class="brands-category-list">{{ other_html }}</div>
        </div>
      {% endif %}
    </div>
  </div>
{% else %}
  {%- if page.metafields.custom.chapter_two and block.settings.show_on != 'chapter_two' -%}
    {% break %}
  {%- elsif page.metafields.custom.chapter_two == blank and block.settings.show_on != 'headzup' -%}
    {% break %}
  {%- endif -%}
  <div class="menu__block {{ width_class }}" {{ block.shopify_attributes }}
    {% if link_level_next %}
      data-animates="{{ link_level_next }}"
      data-animation="{{ animation_name }}"
      data-animation-delay="{{ animation_delay }}"
      data-animation-duration="{{ animation_duration }}"
    {% endif %}>
    <div class="header__dropdown__image palette--contrast--dark"
      {% unless text_color == 'rgba(0,0,0,0)' or text_color == blank %}style="--text: {{ text_color }};"{% endunless %}
      data-stagger-first>
      {%- if link != blank -%}
        <a href="{{ link }}" class="link-over-image">
      {%- else -%}
        <div class="link-over-image">
      {%- endif -%}

        <div class="hero__content__wrapper align--bottom-left">
          <div class="hero__content hero__content--transparent backdrop--radial">
            {%- if title != blank -%}
              <h2 class="hero__title {{ block.settings.heading_font_size }}">
                {{ title | escape }}

                {%- render 'superscript', link_collection: link -%}
              </h2>
            {%- endif -%}

            {%- if text != blank -%}
              <p class="hero__description {{ block.settings.text_font_size }}">
                {{ text | escape }}
              </p>
            {%- endif -%}
          </div>
        </div>

      {%- if link != blank -%}
        </a>
      {%- else -%}
        </div>
      {%- endif -%}

      <div class="image-overlay" style="--overlay-bg: {{ block.settings.overlay_color }}; --overlay-opacity: {{ block.settings.overlay_opacity | times: 0.01 }};"></div>

      {%- render 'image', image: image, aspect_ratio: aspect_ratio, sizes: sizes, loading: 'lazy', fetchpriority: 'high' -%}
    </div>
  </div>
{% endif %}