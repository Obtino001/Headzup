{%- style -%}
  .stock-block-{{ block.id }} {
    margin-block: {{ block.settings.padding_bottom }}px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-family: inherit;
  }

  .stock-block-{{ block.id }} .info-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px; /* Tighter gap to match the screenshot */
  }

  /* Icon wrapper: Scaled 2.5x of the dot width to ensure the pulse halo doesn't get clipped */
  .stock-block-{{ block.id }} .info-icon {
    width: calc({{ block.settings.icon_width }}px * 2.5);
    height: calc({{ block.settings.icon_width }}px * 2.5);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
  }

  .stock-block-{{ block.id }} .info-icon img {
    width: 100%;
    height: auto;
    display: block;
    z-index: 2;
  }

  /* Inner Solid Green Dot */
  .green-dot-fallback {
    width: {{ block.settings.icon_width }}px;
    height: {{ block.settings.icon_width }}px;
    background-color: #00c853; /* Match specific green from image */
    border-radius: 50%;
    position: relative;
    z-index: 2;
  }

  /* Outer Pulsing Halo Animation */
  .green-dot-fallback::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 250%; /* Creates the outer ring */
    height: 250%;
    background-color: rgba(0, 200, 83, 0.22); /* Lighter transparent green */
    border-radius: 50%;
    z-index: 1;
    animation: stockPulse-{{ block.id }} 2.2s infinite cubic-bezier(0.4, 0, 0.2, 1);
  }

  @keyframes stockPulse-{{ block.id }} {
    0% {
      transform: translate(-50%, -50%) scale(0.85);
      opacity: 0.6;
    }
    50% {
      transform: translate(-50%, -50%) scale(1.15);
      opacity: 1;
    }
    100% {
      transform: translate(-50%, -50%) scale(0.85);
      opacity: 0.6;
    }
  }

  /* Text Styling */
  .stock-block-{{ block.id }} .info-text {
    font-size: {{ block.settings.font_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.2;
    font-weight: 400; 
    letter-spacing: 0;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 4px;
  }
  
  /* Bold "In Stock" styling */
  .stock-status-bold {
    font-weight: 500;
    color: {{ block.settings.text_color }};
  }

  .dynamic-date {
     font-weight: 400;
  }
{%- endstyle -%}

<div class="shipping-info-block stock-block-{{ block.id }}" {% unless product.selected_or_first_available_variant.available %}style="display: none;"{% endunless %} {{ block.shopify_attributes }}>
  <div class="info-row">
    
    <div class="info-icon">
      {%- if block.settings.icon_image != blank -%}
        {{ block.settings.icon_image | image_url: width: 100 | image_tag: loading: 'lazy' }}
      {%- else -%}
        <div class="green-dot-fallback"> </div>
      {%- endif -%}
    </div>

    <div class="info-text">
      <span class="stock-status-bold">{{ block.settings.status_text }}</span> 
      <span id="pre-date-{{ block.id }}">
        {%- if block.settings.pre_date_text != blank -%}
          • {{ block.settings.pre_date_text }}
        {%- endif -%}
      </span> 
      
      {%- if block.settings.date_type == 'dynamic' -%}
        <span class="dynamic-date" id="date-{{ block.id }}">...</span>
      {%- else -%}
        <span class="dynamic-date">{{ block.settings.hardcoded_text }}</span>
      {%- endif -%}
    </div>
    
  </div>
</div>

{%- if block.settings.date_type == 'dynamic' -%}
<script>
  document.addEventListener("DOMContentLoaded", function() {
    const deliveryDaysEnd = parseInt({{ block.settings.delivery_days | default: 3 }}); 
    const deliveryDaysStart = Math.max(1, deliveryDaysEnd - 2); 
    const weekdayCutoff = parseInt({{ block.settings.cutoff_weekday | default: 15 }});
    const saturdayCutoff = parseInt({{ block.settings.cutoff_saturday | default: 14 }});
    const enableSmartCutoff = {{ block.settings.smart_cutoff_text | default: true }};
    
    // Get exact current date & time in Denmark (Europe/Copenhagen) regardless of user's local device timezone
    const copenhagenTimeStr = new Date().toLocaleString("en-US", { timeZone: "Europe/Copenhagen" });
    const now = new Date(copenhagenTimeStr);
    const day = now.getDay(); // 0: Sun, 1-5: Mon-Fri, 6: Sat
    const hour = now.getHours();
    
    let isBeforeCutoff = false;
    let dispatchDaysAdd = 0;
    
    if (day >= 1 && day <= 5) {
      if (hour < weekdayCutoff) {
        isBeforeCutoff = true;
        dispatchDaysAdd = 0; // Ships today
      } else if (day === 5) {
        // Friday after 15:00 -> Ships Saturday (since shipping is Mon-Sat)
        dispatchDaysAdd = 1;
      } else {
        // Mon-Thu after 15:00 -> Ships tomorrow
        dispatchDaysAdd = 1;
      }
    } else if (day === 6) {
      if (hour < saturdayCutoff) {
        isBeforeCutoff = true;
        dispatchDaysAdd = 0; // Ships today Saturday
      } else {
        // Saturday after 14:00 -> Ships Monday (skip Sunday)
        dispatchDaysAdd = 2;
      }
    } else {
      // Sunday -> Ships Monday
      dispatchDaysAdd = 1;
    }
    
    // Calculate Dispatch Date using exact Copenhagen base date
    const dispatchDate = new Date(now.getTime());
    dispatchDate.setDate(now.getDate() + dispatchDaysAdd);
    
    // Calculate Start & End Date based on dispatch date + transit days
    const startDate = new Date(dispatchDate.getTime());
    startDate.setDate(dispatchDate.getDate() + deliveryDaysStart);
    
    const endDate = new Date(dispatchDate.getTime());
    endDate.setDate(dispatchDate.getDate() + deliveryDaysEnd);
    
    // Formatting function
    const locale = "{{ request.locale.iso_code }}".toLowerCase();
    const isDanish = locale.startsWith("da");
    
    const formatDate = (date) => isDanish ? `${date.getDate()}.` : date.getDate();
    let month = endDate.toLocaleString(locale, { month: 'short' }).toLowerCase();
    if (month.endsWith('.')) {
      month = month.slice(0, -1);
    }
    const year = endDate.getFullYear();
    
    const dateElement = document.getElementById("date-{{ block.id }}");
    const preDateElement = document.getElementById("pre-date-{{ block.id }}");
    
    if (dateElement) {
      if (isDanish) {
        dateElement.textContent = `${formatDate(startDate)} - ${formatDate(endDate)} ${month}. ${year}`;
      } else {
        dateElement.textContent = `${formatDate(startDate)} - ${formatDate(endDate)} ${month}, ${year}`;
      }
    }
    
    if (enableSmartCutoff && preDateElement) {
      if (isDanish) {
        if (isBeforeCutoff) {
          if (day === 6) {
            preDateElement.textContent = `• Bestil inden kl. ${saturdayCutoff}.00 i dag – forventet levering:`;
          } else {
            preDateElement.textContent = `• Bestil inden kl. ${weekdayCutoff}.00 i dag – forventet levering:`;
          }
        } else {
          preDateElement.textContent = `• Bestil nu – forventet levering:`;
        }
      } else {
        if (isBeforeCutoff) {
          const cutoffFormatted = day === 6 ? saturdayCutoff : weekdayCutoff;
          preDateElement.textContent = `• Order before ${cutoffFormatted}:00 today and get it by`;
        } else {
          preDateElement.textContent = `• Order now and get it by`;
        }
      }
    } else if (preDateElement && preDateElement.textContent.trim().length > 0) {
      const currentText = preDateElement.textContent.trim();
      if (!currentText.startsWith('•')) {
        preDateElement.textContent = `• ${currentText}`;
      }
    }
  });
</script>
{%- endif -%}