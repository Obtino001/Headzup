<div class="estimated-delivery" style="margin: 10px 0; font-size: 0.9em; display: flex; align-items: center; gap: 8px;">
  {% render 'icon-truck' %}
  <span id="estimated-delivery-text"></span>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    function calculateDelivery() {
      // Set timezone to Denmark (CET/CEST)
      const now = new Date();
      const options = { timeZone: 'Europe/Copenhagen', hour: 'numeric', hour12: false };
      const currentHour = parseInt(new Intl.DateTimeFormat('en-GB', options).format(now));
      
      let deliveryDays = 1; // Base delivery time
      // If past 14:00 (2pm), add 1 day
      if (currentHour >= 14) {
        deliveryDays += 1;
      }

      // Add days, skipping weekends
      let deliveryDate = new Date();
      let addedDays = 0;
      while (addedDays < deliveryDays) {
        deliveryDate.setDate(deliveryDate.getDate() + 1);
        // 0 is Sunday, 6 is Saturday
        if (deliveryDate.getDay() !== 0 && deliveryDate.getDay() !== 6) {
          addedDays++;
        }
      }

      const formattingOptions = { weekday: 'long', month: 'long', day: 'numeric' };
      const formattedDate = deliveryDate.toLocaleDateString('en-US', formattingOptions);
      
      const el = document.getElementById('estimated-delivery-text');
      if (el) {
        el.innerHTML = `<strong>Order now</strong> — estimated delivery: ${formattedDate}`;
      }
    }
    
    calculateDelivery();
  });
</script>
