{%- style -%}
  .btb-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    border-top: 1px solid {{ section.settings.border_color }};
    border-bottom: 1px solid {{ section.settings.border_color }};
    padding: 14px 20px;
    width: 100%;
  }
  
  .btb-i-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }
  
  .btb-col-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 5px;
    flex: 1;
    padding: 0 30px;
  }
  
  .btb-col-{{ section.id }}.align-left { align-items: flex-start; text-align: left; }
  .btb-col-{{ section.id }}.align-center { align-items: center; text-align: center; }
  .btb-col-{{ section.id }}.align-right { align-items: flex-end; text-align: right; }

  .btb-line-{{ section.id }} {
    width: 1px;
    height: 26px;
    background: {{ section.settings.divider_color }};
    flex-shrink: 0;
  }
  
  .btb-row-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
  }
  
  .btb-name-{{ section.id }} {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 10px;
    font-weight: bold;
    letter-spacing: 0.08em;
    color: {{ section.settings.text_color }};
  }
  
  .btb-score-{{ section.id }} {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 18px;
    font-weight: bold;
    color: {{ section.settings.text_color }};
  }
  
  .btb-stars-{{ section.id }} {
    display: flex;
    gap: 2px;
  }
  
  .btb-star-{{ section.id }} {
    width: 14px;
    height: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .btb-sub-{{ section.id }} {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 8px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: {{ section.settings.subtext_color }};
    white-space: nowrap;
  }
  
  .btb-num-{{ section.id }} {
    font-family: Georgia, serif;
    font-size: 18px;
    color: {{ section.settings.text_color }};
  }
  
  .btb-italic-{{ section.id }} {
    font-family: Georgia, serif;
    font-style: italic;
    font-size: 15px;
    color: {{ section.settings.text_color }};
  }
  
  @media screen and (max-width: 640px) {
    .btb-{{ section.id }} {
      overflow-x: auto;
    }
    .btb-i-{{ section.id }} {
      min-width: 600px;
    }
    .btb-col-{{ section.id }} {
      padding: 0 14px;
    }
  }
{%- endstyle -%}

<div class="btb-{{ section.id }}">
  <div class="btb-i-{{ section.id }}">
    
    {%- for block in section.blocks -%}
      {%- unless forloop.first -%}
        <div class="btb-line-{{ section.id }}"></div>
      {%- endunless -%}

      <div class="btb-col-{{ section.id }} align-{{ block.settings.alignment }}" {{ block.shopify_attributes }}>
        
        {%- case block.type -%}
          
          {%- when 'trustpilot' -%}
            <div class="btb-row-{{ section.id }}">
              {%- if block.settings.main_icon != blank -%}
                {{ block.settings.main_icon }}
              {%- endif -%}
              <span class="btb-name-{{ section.id }}">{{ block.settings.title }}</span>
              <span class="btb-score-{{ section.id }}">{{ block.settings.score }}</span>
            </div>
            <div class="btb-row-{{ section.id }}">
              <div class="btb-stars-{{ section.id }}">
                {%- for i in (1..5) -%}
                  <div class="btb-star-{{ section.id }}" style="background: {{ block.settings.star_bg_color }};">
                    <svg viewBox="0 0 24 24" fill="{{ block.settings.star_icon_color }}" width="8" height="8"><path d="M12 2l2.9 8.9H24l-7.6 5.5 2.9 8.9L12 20l-7.3 5.3 2.9-8.9L0 10.9h9.1z"/></svg>
                  </div>
                {%- endfor -%}
              </div>
              <span class="btb-sub-{{ section.id }}">{{ block.settings.subtext }}</span>
            </div>

          {%- when 'stats' -%}
            <span class="btb-num-{{ section.id }}">{{ block.settings.number }}</span>
            <span class="btb-sub-{{ section.id }}">{{ block.settings.subtext }}</span>

          {%- when 'brand' -%}
            <div class="btb-row-{{ section.id }}">
              {%- if block.settings.icon != blank -%}
                {{ block.settings.icon }}
              {%- endif -%}
              <em class="btb-italic-{{ section.id }}">{{ block.settings.title }}</em>
            </div>
            <span class="btb-sub-{{ section.id }}">{{ block.settings.subtext }}</span>

        {%- endcase -%}
        
      </div>
    {%- endfor -%}
    
  </div>
</div>

{% schema %}
{
  "name": "Trust Banner",
  "settings": [
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Maximum Width",
      "default": 1200
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FAF8F4"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#DDD8CF"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider Color",
      "default": "#D0CCC4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext Color",
      "default": "#9A9590"
    }
  ],
  "blocks": [
    {
      "type": "trustpilot",
      "name": "Review Score",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "alignment",
          "label": "Alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "textarea",
          "id": "main_icon",
          "label": "Main SVG Icon",
          "default": "<svg width='14' height='14' viewBox='0 0 24 24' fill='#00B67A'><path d='M12 2l2.9 8.9H24l-7.6 5.5 2.9 8.9L12 20l-7.3 5.3 2.9-8.9L0 10.9h9.1z'/></svg>"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "TRUSTPILOT"
        },
        {
          "type": "text",
          "id": "score",
          "label": "Score",
          "default": "4.4"
        },
        {
          "type": "color",
          "id": "star_bg_color",
          "label": "Star Background Color",
          "default": "#00B67A"
        },
        {
          "type": "color",
          "id": "star_icon_color",
          "label": "Star Icon Color",
          "default": "#FFFFFF"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "default": "· 1 200+ anmeldelser"
        }
      ]
    },
    {
      "type": "stats",
      "name": "Statistics",
      "settings": [
        {
          "type": "select",
          "id": "alignment",
          "label": "Alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "center"
        },
        {
          "type": "text",
          "id": "number",
          "label": "Main Number",
          "default": "200 000 +"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "default": "sengetøy solgt i Norge"
        }
      ]
    },
    {
      "type": "brand",
      "name": "Brand Feature",
      "settings": [
        {
          "type": "select",
          "id": "alignment",
          "label": "Alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "textarea",
          "id": "icon",
          "label": "SVG Icon",
          "default": "<svg width='22' height='14' viewBox='0 0 22 14' fill='none'><rect width='22' height='14' fill='#EF2B2D'/><rect y='5' width='22' height='4' fill='white'/><rect x='6' y='0' width='4' height='14' fill='white'/><rect y='5.6' width='22' height='2.8' fill='#002868'/><rect x='6.6' y='0' width='2.8' height='14' fill='#002868'/></svg>"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Norsk merkevare"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "default": "Skandinavisk kvalitet siden 2021"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Banner",
      "blocks": [
        { "type": "trustpilot" },
        { "type": "stats" },
        { "type": "brand" }
      ]
    }
  ]
}
{% endschema %}