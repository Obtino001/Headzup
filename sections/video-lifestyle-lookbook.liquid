

<style>
  #bli-inspirert-{{ section.id }} {
    --bg: {{ section.settings.background_color }};
    --text-primary: #1A1A1A;
    --sage: {{ section.settings.accent_color }};
    --radius-img: {{ section.settings.border_radius }}px;
  }

  #bli-inspirert-{{ section.id }} {
    background: var(--bg);
    padding: 46px 0 80px;
    overflow: hidden;
  }

  #bli-inspirert-{{ section.id }} .insp-header {
    padding: 0 clamp(24px, 6vw, 96px);
    margin-bottom: 52px;
  }

  #bli-inspirert-{{ section.id }} .insp-eyebrow {
    font-family: var(--font);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--text-primary);
    text-transform: uppercase;
    margin-bottom: 14px;
    display: block;
  }

  #bli-inspirert-{{ section.id }} .insp-title {
    font-family: var(--font);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 300;
    color: var(--text-primary);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }

  #bli-inspirert-{{ section.id }} .insp-subtitle {
    font-family: var(--font);
    font-size: 15px;
    font-weight: 400;
    color: var(--text-primary);
    line-height: 1.7;
    max-width: 480px;
  }

  #bli-inspirert-{{ section.id }} .insp-track-outer {
    position: relative;
    width: 100%;
    overflow: hidden;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
  }

  #bli-inspirert-{{ section.id }} .insp-track-outer:active { cursor: grabbing; }

  #bli-inspirert-{{ section.id }} .insp-track-outer::before,
  #bli-inspirert-{{ section.id }} .insp-track-outer::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    width: clamp(24px, 5vw, 80px);
    z-index: 2;
    pointer-events: none;
  }

  #bli-inspirert-{{ section.id }} .insp-track-outer::before {
    left: 0;
    background: linear-gradient(to right, var(--bg), transparent);
  }

  #bli-inspirert-{{ section.id }} .insp-track-outer::after {
    right: 0;
    background: linear-gradient(to left, var(--bg), transparent);
  }

  #bli-inspirert-{{ section.id }} .insp-track {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 0 clamp(24px, 6vw, 96px) 24px;
    will-change: transform;
  }

  #bli-inspirert-{{ section.id }} .insp-card {
    flex-shrink: 0;
    width: clamp(200px, 22vw, 300px);
    height: clamp(250px, 27.5vw, 375px);
    border-radius: var(--radius-img);
    overflow: hidden;
    position: relative;
    background: #E8E2DA;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  #bli-inspirert-{{ section.id }} .insp-card:hover {
    transform: translateY(-4px);
  }

  #bli-inspirert-{{ section.id }} .insp-card img,
  #bli-inspirert-{{ section.id }} .insp-card svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  #bli-inspirert-{{ section.id }} .insp-card:hover img {
    transform: scale(1.03);
  }

  #bli-inspirert-{{ section.id }} .insp-caption {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    z-index: 2;
    padding: 40px 16px 16px;
    background: linear-gradient(to top, rgba(20,18,16,0.55), transparent);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.35s ease, transform 0.35s ease;
    pointer-events: none;
    border-radius: 0 0 var(--radius-img) var(--radius-img);
  }

  #bli-inspirert-{{ section.id }} .insp-card:hover .insp-caption {
    opacity: 1;
    transform: translateY(0);
  }

  @media (hover: none) {
    #bli-inspirert-{{ section.id }} .insp-caption {
      opacity: 1;
      transform: translateY(0);
      padding: 28px 14px 12px;
      background: linear-gradient(to top, rgba(20,18,16,0.45), transparent);
    }
  }

  #bli-inspirert-{{ section.id }} .insp-caption-label {
    display: block;
    font-family: var(--font);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    margin-bottom: 3px;
  }

  #bli-inspirert-{{ section.id }} .insp-caption-title {
    display: block;
    font-family: var(--font);
    font-size: 13px;
    font-weight: 300;
    color: rgba(255,255,255,0.9);
    line-height: 1.4;
  }

  #bli-inspirert-{{ section.id }} .insp-card a.card-link {
    display: block;
    position: absolute;
    inset: 0;
    z-index: 3;
  }

  #bli-inspirert-{{ section.id }} .insp-progress {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 28px clamp(24px, 6vw, 96px) 0;
  }

  #bli-inspirert-{{ section.id }} .insp-progress-bar {
    width: 48px;
    height: 2px;
    background: #E0DAD3;
    border-radius: 2px;
    transition: width 0.2s;
  }

  #bli-inspirert-{{ section.id }} .insp-progress-bar.active {
    width: 72px;
    background: var(--sage);
  }

  @media (max-width: 640px) {
    #bli-inspirert-{{ section.id }} { padding: 64px 0 56px; }
    #bli-inspirert-{{ section.id }} .insp-header { margin-bottom: 36px; }
    #bli-inspirert-{{ section.id }} .insp-card { width: 68vw; height: 85vw; }
    #bli-inspirert-{{ section.id }} .insp-track { gap: 10px; }
    #bli-inspirert-{{ section.id }} .insp-track-outer::before,
    #bli-inspirert-{{ section.id }} .insp-track-outer::after { width: 16px; }
  }

  @media (prefers-reduced-motion: reduce) {
    #bli-inspirert-{{ section.id }} .insp-card,
    #bli-inspirert-{{ section.id }} .insp-card img { transition: none !important; }
  }
</style>

<section id="bli-inspirert-{{ section.id }}" aria-label="Bli inspirert – inspirasjonskarusell">

  <div class="insp-header">
    {% if section.settings.eyebrow != blank %}
      <p class="insp-eyebrow" aria-hidden="true">{{ section.settings.eyebrow }}</p>
    {% endif %}
    {% if section.settings.title != blank %}
      <h2 class="insp-title">{{ section.settings.title }}</h2>
    {% endif %}
    {% if section.settings.subtitle != blank %}
      <p class="insp-subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}
  </div>

  <div class="insp-track-outer" id="insp-outer-{{ section.id }}">
    <div class="insp-track" id="insp-track-{{ section.id }}">
      {% for block in section.blocks %}
        {% if block.type == 'image' %}
          <div class="insp-card" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.image.alt | default: block.settings.caption, draggable: 'false' }}
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
            {% if block.settings.label != blank or block.settings.caption != blank %}
              <div class="insp-caption">
                {% if block.settings.label != blank %}
                  <span class="insp-caption-label">{{ block.settings.label }}</span>
                {% endif %}
                {% if block.settings.caption != blank %}
                  <span class="insp-caption-title">{{ block.settings.caption }}</span>
                {% endif %}
              </div>
            {% endif %}
            {% if block.settings.link != blank %}
              <a class="card-link" href="{{ block.settings.link }}" aria-label="{{ block.settings.caption | default: 'Se produkt' }}"></a>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="insp-progress" id="insp-progress-{{ section.id }}" role="tablist" aria-label="Karusell-navigasjon"></div>

</section>

<script>
(function () {
  var sectionId = '{{ section.id }}';
  var track = document.getElementById('insp-track-' + sectionId);
  var outer = document.getElementById('insp-outer-' + sectionId);
  var progressWrap = document.getElementById('insp-progress-' + sectionId);

  if (!track || !outer) return;

  var speed = {{ section.settings.scroll_speed | default: 55 }} / 100;
  var pauseOnHover = {{ section.settings.pause_on_hover | default: true }};
  var gap = 14;
  var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  var originalCards = Array.from(track.querySelectorAll('.insp-card'));
  var totalOriginal = originalCards.length;
  if (totalOriginal === 0) return;

  originalCards.forEach(function(card) {
    var clone = card.cloneNode(true);
    clone.setAttribute('aria-hidden', 'true');
    track.appendChild(clone);
  });

  originalCards.forEach(function(_, i) {
    var bar = document.createElement('div');
    bar.className = 'insp-progress-bar' + (i === 0 ? ' active' : '');
    bar.setAttribute('role', 'tab');
    bar.setAttribute('aria-label', 'Bilde ' + (i + 1) + ' av ' + totalOriginal);
    progressWrap.appendChild(bar);
  });

  var bars = progressWrap.querySelectorAll('.insp-progress-bar');

  function setActive(idx) {
    bars.forEach(function(b, i) {
      b.classList.toggle('active', i === idx);
    });
  }

  var pos = 0;
  var paused = false;
  var halfWidth = 0;

  function calcHalf() {
    var w = 0;
    originalCards.forEach(function(card) { w += card.offsetWidth + gap; });
    halfWidth = w;
  }

  function tick() {
    if (!paused && !prefersReduced) {
      pos += speed;
      if (pos >= halfWidth) pos -= halfWidth;
      track.style.transform = 'translateX(-' + pos + 'px)';

      var outerRect = outer.getBoundingClientRect();
      var cx = outerRect.left + outerRect.width / 2;
      var closest = 0;
      var minDist = Infinity;
      originalCards.forEach(function(card, i) {
        var r = card.getBoundingClientRect();
        var dist = Math.abs((r.left + r.width / 2) - cx);
        if (dist < minDist) { minDist = dist; closest = i; }
      });
      setActive(closest);
    }
    requestAnimationFrame(tick);
  }

  function init() {
    calcHalf();
    requestAnimationFrame(tick);
  }

  if (document.readyState === 'complete') { init(); }
  else { window.addEventListener('load', init); }

  window.addEventListener('resize', calcHalf);

  if (pauseOnHover) {
    outer.addEventListener('mouseenter', function() { paused = true; });
    outer.addEventListener('mouseleave', function() { paused = false; });
  }

  var isDragging = false, startX = 0, startPos = 0, velX = 0, lastX = 0, lastT = 0;

  function pointerDown(e) {
    isDragging = true; paused = true;
    startX = e.type.indexOf('touch') === 0 ? e.touches[0].clientX : e.clientX;
    startPos = pos; lastX = startX; lastT = Date.now();
    outer.style.cursor = 'grabbing';
  }

  function pointerMove(e) {
    if (!isDragging) return;
    var cx = e.type.indexOf('touch') === 0 ? e.touches[0].clientX : e.clientX;
    var now = Date.now();
    velX = (cx - lastX) / (now - lastT + 1);
    lastX = cx; lastT = now;
    pos = startPos + (startX - cx);
    if (pos < 0) pos += halfWidth;
    if (pos >= halfWidth) pos -= halfWidth;
    track.style.transform = 'translateX(-' + pos + 'px)';
  }

  function pointerUp() {
    if (!isDragging) return;
    isDragging = false;
    outer.style.cursor = 'grab';
    var v = -velX * 12;
    function coast() {
      if (Math.abs(v) < 0.3) { paused = false; return; }
      pos += v;
      if (pos < 0) pos += halfWidth;
      if (pos >= halfWidth) pos -= halfWidth;
      track.style.transform = 'translateX(-' + pos + 'px)';
      v *= 0.92;
      requestAnimationFrame(coast);
    }
    coast();
  }

  outer.addEventListener('mousedown', pointerDown);
  window.addEventListener('mousemove', pointerMove);
  window.addEventListener('mouseup', pointerUp);
  outer.addEventListener('touchstart', pointerDown, { passive: true });
  outer.addEventListener('touchmove', pointerMove, { passive: true });
  outer.addEventListener('touchend', pointerUp);
  outer.addEventListener('dragstart', function(e) { e.preventDefault(); });
})();
</script>

{% schema %}
{
  "name": "Bli inspirert",
  "tag": "section",
  "class": "bli-inspirert-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow-tekst",
      "default": "Inspirasjon"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Overskrift",
      "default": "Bli inspirert"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Undertittel",
      "default": "Se hvordan bambus-sengetøyet kan styles i ulike farger, rom og stemninger."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Bakgrunnsfarge",
      "default": "#FAF7F3"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Aksentfarge",
      "default": "#A0AFA0"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Avrunding på bilder",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scrollehastighet (lavere = saktere)",
      "min": 20,
      "max": 150,
      "step": 5,
      "default": 55
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause ved hover",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Bilde",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bilde"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "placeholder": "Sengesett · Skoggrønn"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Bildetekst",
          "placeholder": "Bambus sengesett – 200×200 cm"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (valgfri)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bli inspirert",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}